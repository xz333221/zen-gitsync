# Auto-generated log
git-autocommit.log

# Claude / AI worktrees
.claude/*
# 例外：ui-ux-pro-max 是项目级设计规范 skill（`uipro init --ai claude` 装入）
!.claude/skills/
# 例外：项目级 Claude 规则文件(.claude/rules/ 是项目规范文档,跨会话加载)
!.claude/rules/
.claude/settings.json
.claude/settings.local.json
.claude/launch.json

# Python 编译缓存（ui-ux-pro-max skill 的 search.py 生成的 .pyc）
__pycache__/
*.pyc

# CodeBuddy project data
.codebuddy/

# TypeScript build info
*.tsbuildinfo

# ESLint cache
.eslintcache

# Test coverage
coverage/

# Playwright
src/ui/client/playwright-report/
src/ui/client/test-results/
src/ui/client/blob-report/
src/ui/client/playwright/.cache/

# Windows thumbnail cache
Thumbs.db

# Temp directories
.temp/
tmp/

# E2E 验证产生的截图产物（按 task id 分子目录，一次性产物不入库）
workbench-images/

.npmrc
