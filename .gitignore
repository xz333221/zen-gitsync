.DS_Store
node_modules
/dist


# local env files
.env.local
.env.*.local

# i18n secret config (百度翻译 API 密钥)
i18n.secret.js
i18n.secret.cjs

src/ui/client/lib/

# 前端 build 产物（每个 hash 命名的文件都进 git 会污染 history；本地 build 后会重新生成）
src/ui/public/index.html
src/ui/public/assets/*

# 旧版被删除的 font-awesome/file-icons/devopicons/mfixx/octicons 字体
src/ui/public/assets/*.woff2
src/ui/public/assets/*.ttf

# Log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editor directories and files
.idea
.vscode
.qoder

*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

package-lock.json
yarn.lock
pnpm-lock.yaml
# pnpm 11 自动写入的 minimumReleaseAgeExclude 等本地抑制配置,跟 pnpm-lock.yaml 同性质
pnpm-workspace.yaml
.port

# Auto-generated log
git-autocommit.log

# Claude / AI worktrees
.claude/*
# 例外：ui-ux-pro-max 是项目级设计规范 skill（`uipro init --ai claude` 装入）
!.claude/skills/
!.claude/skills/**
# 例外：项目级 Claude 规则文件(.claude/rules/ 是项目规范文档,跨会话加载)
!.claude/rules/
!.claude/rules/**
# Claude Code post_tool_hook 写到 cwd/.claude/codediff.txt（子目录里的 .claude/ 是 hook 产物，非项目规范）。
# 根 .claude/* 规则不递归到子目录，这里用精确路径替代 `**/.claude/`，避免父目录被屏蔽后子目录例外失效。
**/.claude/codediff.txt
.claude/settings.json
.claude/settings.local.json
.claude/launch.json

# Python 编译缓存（ui-ux-pro-max skill 的 search.py 生成的 .pyc）
__pycache__/
*.pyc

# CodeBuddy project data
.codebuddy/


# 其它 AI 工具本地副本(已删除,内容已迁移到 .claude/skills/)
# 保留 .gitignore 规则防止后续误创建再被追踪
.trae/
.windsurf/
.iflow/
# WorkBuddy workspace data（工作日志/缓存，本地数据，不入库）
.workbuddy/

# TypeScript build info
*.tsbuildinfo

# ESLint cache
.eslintcache

# Test coverage
coverage/

# Playwright
src/ui/client/playwright-report/
src/ui/client/test-results/
src/ui/client/blob-report/
src/ui/client/playwright/.cache/

# Windows thumbnail cache
Thumbs.db

# Temp directories
.temp/
tmp/

# E2E 验证产生的截图产物（按 task id 分子目录，一次性产物不入库）
workbench-images/

.npmrc
